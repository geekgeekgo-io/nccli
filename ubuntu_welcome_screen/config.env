# =============================================================================
# Ubuntu Welcome Screen Configuration
# =============================================================================
# Edit these values and re-run setup-welcome-screen.sh to apply changes

# The text to display as ASCII art
# Leave empty to use the hostname automatically
WELCOME_TEXT=""

# ASCII art font
# Popular options: standard, slant, banner, big, block, bubble, digital, lean, small
# Run 'figlet -l' on target server to see all available fonts
ASCII_FONT="slant"

# Color for ASCII art
# Options: red, green, yellow, blue, magenta, cyan, white
ASCII_COLOR="cyan"

# Show system information (true/false)
SHOW_SYSTEM_INFO=true
